generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                    @id @default(autoincrement())
  email              String                 @unique
  password           String?
  name               String                 @default("Reader")
  role               String                 @default("reader")
  avatarUrl          String?
  bio                String?
  emailVerifiedAt    DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime               @default(now())
  comments           Comment[]
  emailTokens        EmailToken[]
  bookmarks          Bookmark[]
  readingHistory     ReadingHistory[]
  newsletterIssues   NewsletterIssue[]      @relation("NewsletterIssueAuthor")
  newsletterProfile  NewsletterSubscriber?
}

model Post {
  id          Int        @id @default(autoincrement())
  title       String
  slug        String     @unique
  deck        String?
  excerpt     String     @default("")
  content     String
  contentFormat String   @default("markdown")
  coverImage  String?
  coverAlt    String?
  sourceUrl   String?
  published   Boolean    @default(false)
  featured    Boolean    @default(false)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  categoryId  Int?
  category    Category?  @relation(fields: [categoryId], references: [id])
  comments    Comment[]
  meta        PostMeta?
  seriesId    Int?
  seriesOrder Int?
  series      Series?    @relation(fields: [seriesId], references: [id])
  tags        PostTag[]
  analyticsEvents AnalyticsEvent[]
  externalLinks ExternalPostLink[]
  bookmarks   Bookmark[]
  readingHistory ReadingHistory[]
}

model Tag {
  id    Int       @id @default(autoincrement())
  name  String    @unique
  slug  String    @unique
  posts PostTag[]
}

model PostTag {
  postId Int
  tagId  Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model Comment {
  id        Int       @id @default(autoincrement())
  content   String
  author    String
  email     String?
  postId    Int
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  parentId  Int?
  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
  status    String    @default("pending")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PostMeta {
  id       Int  @id @default(autoincrement())
  postId   Int  @unique
  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  views    Int  @default(0)
  likes    Int  @default(0)
  readTime Int  @default(0)
}

model Series {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  summary     String?
  description String?
  coverImage  String?
  status      String   @default("active")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]

  @@index([status, order])
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  headline    String?
  summary     String   @default("")
  description String
  techStack   String   @default("")
  status      String?
  period      String?
  role        String?
  liveUrl     String?
  repoUrl     String?
  coverImage  String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  postId     Int?
  post       Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  type       String
  source     String   @default("web")
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([type, createdAt])
  @@index([postId, createdAt])
}

model ApiKey {
  id         Int       @id @default(autoincrement())
  name       String
  keyPrefix  String    @unique
  keyHash    String    @unique
  scopes     String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ExternalPostLink {
  id              Int      @id @default(autoincrement())
  provider        String
  externalId      String
  sourceUrl       String?
  lastPayloadHash String?
  postId          Int
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([provider, externalId])
  @@index([postId])
}

model EmailToken {
  id         Int      @id @default(autoincrement())
  email      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([email, purpose, expiresAt])
}

model NewsletterSubscriber {
  id             Int                  @id @default(autoincrement())
  email          String               @unique
  status         String               @default("pending")
  source         String               @default("website")
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  userId         Int?                 @unique
  user           User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deliveries     NewsletterDelivery[]
}

model NewsletterIssue {
  id           Int                  @id @default(autoincrement())
  title        String
  slug         String               @unique
  subject      String
  previewText  String               @default("")
  bodyMarkdown String
  status       String               @default("draft")
  sentAt       DateTime?
  createdById  Int
  createdBy    User                 @relation("NewsletterIssueAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  deliveries   NewsletterDelivery[]
}

model NewsletterDelivery {
  id                Int                  @id @default(autoincrement())
  issueId           Int
  issue             NewsletterIssue      @relation(fields: [issueId], references: [id], onDelete: Cascade)
  subscriberId      Int
  subscriber        NewsletterSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  status            String               @default("pending")
  attemptCount      Int                  @default(0)
  lastAttemptAt     DateTime?
  nextAttemptAt     DateTime?
  lockedAt          DateTime?
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([issueId, subscriberId])
  @@index([status, nextAttemptAt])
  @@index([lockedAt])
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model ReadingHistory {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId       Int
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  lastViewedAt DateTime @default(now())
  viewCount    Int      @default(1)
  createdAt    DateTime @default(now())

  @@unique([userId, postId])
  @@index([lastViewedAt])
}

model HomepageSection {
  id          Int      @id @default(autoincrement())
  type        String
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  sourceType  String   @default("manual")
  eyebrow     String?
  title       String?
  description String?
  ctaLabel    String?
  ctaHref     String?
  configJson  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type])
  @@index([enabled, sortOrder])
}
