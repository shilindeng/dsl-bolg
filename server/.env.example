PORT=3001
# Bind host. Use 127.0.0.1 behind a reverse proxy in production.
HOST=0.0.0.0
DATABASE_URL=file:./prisma/blog.db
JWT_SECRET=replace-with-a-long-random-secret
SITE_NAME=DSL Blog
SITE_URL=https://your-domain.com
API_URL=https://api.your-domain.com
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com,http://localhost:5173

# Turnstile (optional in local dev, recommended in production)
TURNSTILE_SECRET_KEY=

# Mail delivery
# log: print emails to server logs
# resend: send through Resend API
MAIL_PROVIDER=log
MAIL_FROM=no-reply@your-domain.com
RESEND_API_KEY=

# Upload strategy
# local: save to server/uploads
# r2: upload to Cloudflare R2
UPLOAD_MODE=local

# Cloudflare R2 (required when UPLOAD_MODE=r2)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=
